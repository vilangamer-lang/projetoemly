{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "",
  "buildCommand": "echo 'Static site - no build step'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/admin", "destination": "/" },
    { "source": "/p/:slug", "destination": "/assinatura.html?slug=:slug" },
    { "source": "/paciente/:slug", "destination": "/assinatura.html?slug=:slug" },
    { "source": "/assinatura/:slug", "destination": "/assinatura.html?slug=:slug" }
  ]
}
